.venv/

# Папки в репо есть, содержимое — нет
video_samples/*
!video_samples/.gitkeep
outputs/*
!outputs/.gitkeep
/tests/video_samples
/tests/outputs

# Игнорировать все pyc-файлы
*.pyc

# Игнорировать директории __pycache__
__pycache__/
**/__pycache__/

# Игнорировать прочие кэши Python
*.py[co]
*.pyc
*.pyc
*.pyo
*.pyd
*$py.class
app/__pycache__/pose_estimator.cpython-311.pyc

# Игнорировать веса моделей
.pt

Open_pose_samples

# --- ST-GCN (app/stgcn): артефакты сборки, обучения и тяжёлые данные ---
app/stgcn/work_dir/
app/stgcn/torchlight/build/
app/stgcn/torchlight/dist/
app/stgcn/torchlight/torchlight.egg-info/

# NTU / Kinetics: скелеты и массивы (десятки ГБ) — хранить локально или снаружи репо
app/stgcn/data/**/*.npy
app/stgcn/data/**/*.skeleton